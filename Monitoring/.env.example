# ============================================================
# HealthAI Coach - Monitoring Stack
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# Discord Webhook URL (obligatoire pour les alertes)
# Creer sur Discord : Paramètres serveur → Intégrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX

# PostgreSQL (doit correspondre au Backend/.env)
DB_USERNAME=sail
DB_PASSWORD=password
DB_DATABASE=laravel

# MongoDB (doit correspondre au API-Ollama/docker-compose.yml)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
